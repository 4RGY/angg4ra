---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import BentoCard from '../../components/ui/BentoCard.astro';

// Single source of truth untuk icon dan kategori
const skillCategories = [
  {
    id: 'data',
    category: 'Data & Analytics',
    color: 'var(--accent-data)',
    hex: '6A8F6E',
    featuredIcons: [
      { name: 'Python',       slug: 'python' },
      { name: 'Pandas',       slug: 'pandas' },
      { name: 'Scikit-learn', slug: 'scikitlearn' },
      { name: 'NumPy',        slug: 'numpy' },
      { name: 'Jupyter',      slug: 'jupyter' },
      { name: 'Kaggle',       slug: 'kaggle' },
    ],
    extraTools: ['SHAP', 'Matplotlib', 'Seaborn', 'SQL']
  },
  {
    id: 'web',
    category: 'Web Development',
    color: 'var(--accent-sci)',
    hex: '3A6B7A',
    featuredIcons: [
      { name: 'JavaScript',   slug: 'javascript' },
      { name: 'TypeScript',   slug: 'typescript' },
      { name: 'Astro',        slug: 'astro' },
      { name: 'Next.js',      slug: 'nextdotjs' },
      { name: 'React',        slug: 'react' },
      { name: 'Tailwind',     slug: 'tailwindcss' },
    ],
    extraTools: ['Framer Motion', 'HTML & CSS']
  },
  {
    id: 'tools',
    category: 'Tools & Lainnya',
    color: 'var(--accent)',
    hex: '6B2D3E',
    featuredIcons: [
      { name: 'Git',          slug: 'git' },
      { name: 'GitHub',       slug: 'github' },
      { name: 'Figma',        slug: 'figma' },
      { name: 'VS Code',      slug: 'v' },
      { name: 'FastAPI',      slug: 'fastapi' },
      { name: 'SQLite',       slug: 'sqlite' },
      { name: 'Duolingo',     slug: 'duolingo' },
      { name: 'Counter Strike',       slug: 'counterstrike' },
      { name: 'Valorant',     slug: 'valorant'},
      { name: 'Dota 2',       slug: 'dota2'}
    ],
    extraTools: ['Excel', 'Java (Swing)', 'Roblox Studio', 'Lua']
  },
];

const learningItems = [
  { name: 'Machine Learning & Model Deployment', note: 'FastAPI + Docker' },
  { name: 'Data Visualization lanjutan', note: 'D3.js' },
  { name: 'Statistical Modeling', note: 'Statsmodels, SciPy' },
];

// Pisah manual untuk penempatan komponen grid
const dataSkill = skillCategories.find(c => c.id === 'data');
const webSkill = skillCategories.find(c => c.id === 'web');
const toolsSkill = skillCategories.find(c => c.id === 'tools');
---

<BaseLayout title="Skill" lang="id">
  <div class="page-container">
    <h1 class="page-title">Skill</h1>
    <p class="page-desc">Alat dan teknologi yang saya gunakan — dari analisis data sampai membangun antarmuka.</p>

    <div class="bento-grid">
      {dataSkill && (
        <div class="card-md">
          <BentoCard size="md" scanline={true}>
            <p class="section-label font-mono" style={`color: ${dataSkill.color}`}>
              / {dataSkill.category}
            </p>
            <div class="icon-grid">
              {dataSkill.featuredIcons.map(icon => (
                <div class="icon-item">
                  <div class="icon-wrap" style={`--hover-color: ${dataSkill.color}`}>
                    <img
                      src={`https://cdn.simpleicons.org/${icon.slug}/${dataSkill.hex}`}
                      alt={icon.name}
                      width="28"
                      height="28"
                      loading="lazy"
                    />
                  </div>
                  <span class="icon-label font-mono">{icon.name}</span>
                </div>
              ))}
            </div>
          </BentoCard>
        </div>
      )}

      {webSkill && (
        <div class="card-md">
          <BentoCard size="md" scanline={true}>
            <p class="section-label font-mono" style={`color: ${webSkill.color}`}>
              / {webSkill.category}
            </p>
            <div class="icon-grid">
              {webSkill.featuredIcons.map(icon => (
                <div class="icon-item">
                  <div class="icon-wrap" style={`--hover-color: ${webSkill.color}`}>
                    <img
                      src={`https://cdn.simpleicons.org/${icon.slug}/${webSkill.hex}`}
                      alt={icon.name}
                      width="28"
                      height="28"
                      loading="lazy"
                    />
                  </div>
                  <span class="icon-label font-mono">{icon.name}</span>
                </div>
              ))}
            </div>
          </BentoCard>
        </div>
      )}

      {toolsSkill && (
        <div class="card-xl">
          <BentoCard size="xl" scanline={true}>
            <p class="section-label font-mono" style={`color: ${toolsSkill.color}`}>
              / {toolsSkill.category}
            </p>
            <div class="icon-grid wide-icon-grid">
              {toolsSkill.featuredIcons.map(icon => (
                <div class="icon-item">
                  <div class="icon-wrap" style={`--hover-color: ${toolsSkill.color}`}>
                    <img
                      src={`https://cdn.simpleicons.org/${icon.slug}/${toolsSkill.hex}`}
                      alt={icon.name}
                      width="28"
                      height="28"
                      loading="lazy"
                    />
                  </div>
                  <span class="icon-label font-mono">{icon.name}</span>
                </div>
              ))}
            </div>
          </BentoCard>
        </div>
      )}

      <div class="card-xl">
        <BentoCard size="xl">
          <p class="section-label font-mono">/ semua tools & teknologi</p>
          <div class="tools-table">
            {skillCategories.map(row => {
              const allTools = [...row.featuredIcons.map(i => i.name === 'Tailwind' ? 'Tailwind CSS' : i.name), ...row.extraTools];
              
              return (
                <div class="tools-row">
                  <span class="tools-cat font-mono" style={`color: ${row.color}`}>
                    {row.category}
                  </span>
                  <div class="tools-pills">
                    {allTools.map(tool => (
                      <span class="tool-pill font-mono" style={`--hover-color: ${row.color}`}>{tool}</span>
                    ))}
                  </div>
                </div>
              )
            })}
          </div>
        </BentoCard>
      </div>

      <div class="card-md">
        <BentoCard size="md">
          <p class="section-label font-mono">/ sedang dipelajari</p>
          <div class="learning-list">
            {learningItems.map(item => (
              <div class="learning-item">
                <span class="learning-name">{item.name}</span>
                <span class="learning-note font-mono">{item.note}</span>
              </div>
            ))}
          </div>
        </BentoCard>
      </div>

      <div class="card-md">
        <BentoCard size="md">
          <p class="section-label font-mono">/ cara saya belajar</p>
          <blockquote class="learn-quote font-quote">
            "Learning by Doing. Saya belajar paling baik dengan membangun sesuatu yang nyata."
          </blockquote>
          <p class="learn-body">
            Setiap proyek di halaman ini adalah bukti dari proses itu. Dari prediksi kualitas udara Jakarta sampai sistem akademik Java, semuanya lahir dari rasa ingin tahu.
          </p>
        </BentoCard>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  /* Base Layout & Spacing */
  .page-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }
  .page-title {
    margin-bottom: 2rem;
  }
  .page-desc {
    color: var(--text-secondary);
    max-width: 560px;
    font-size: 1rem;
    line-height: 1.5;
    margin-top: -1rem;
    margin-bottom: 2.5rem;
  }

  /* Bento Grid Master System */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 1.5rem;
  }
  .card-md { grid-column: span 6; }
  .card-xl { grid-column: span 12; }

  .section-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
    font-weight: 600;
  }

  /* Icon Grid Standar (Kotak 3 Kolom) */
  .icon-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem 1rem;
  }

  /* FIX: Grid untuk Tools yang manjang ke samping agar deketan */
  .wide-icon-grid {
    grid-template-columns: repeat(auto-fill, minmax(76px, 1fr));
    justify-content: start;
    gap: 1.5rem 1.25rem; /* Jarak horizontal (1.25rem) disetel biar pas dedekatan */
  }

  .icon-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
  }
  .icon-wrap {
    width: 56px;
    height: 56px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-main);
    transition: all 250ms ease;
  }
  .icon-wrap:hover {
    border-color: var(--hover-color);
    transform: translateY(-2px);
    box-shadow: 0 0 15px var(--hover-color);
  }
  .icon-wrap img {
    width: 26px;
    height: 26px;
    object-fit: contain;
    opacity: 0.8;
    transition: all 250ms ease;
  }
  .icon-wrap:hover img { 
    opacity: 1; 
    transform: scale(1.05);
  }
  .icon-label {
    font-size: 0.75rem;
    color: var(--text-secondary);
    text-align: center;
    line-height: 1.2;
  }

  /* Tools Table & Pills */
  .tools-table {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .tools-row {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 1.5rem;
    align-items: start;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }
  .tools-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .tools-cat {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
    padding-top: 0.3rem;
  }
  .tools-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tool-pill {
    font-size: 0.8rem;
    padding: 0.35rem 0.85rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text-primary);
    background: transparent;
    letter-spacing: 0.02em;
    transition: all 200ms ease;
  }
  .tool-pill:hover {
    border-color: var(--hover-color);
    color: var(--hover-color);
    background: rgba(255, 255, 255, 0.02);
    box-shadow: 0 0 10px var(--hover-color);
  }

  /* Learning List */
  .learning-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .learning-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-left: 1rem;
    border-left: 2px solid var(--accent-sci);
  }
  .learning-name {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-primary);
  }
  .learning-note {
    font-size: 0.8rem;
    color: var(--text-secondary);
  }

  /* Quotes */
  .learn-quote {
    font-size: 1.2rem;
    font-style: italic;
    color: var(--text-primary);
    line-height: 1.6;
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
    margin: 0 0 1.5rem 0;
  }
  .learn-body {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* Breakpoint Responsif */
  @media (max-width: 992px) {
    .tools-row {
      grid-template-columns: 150px 1fr;
    }
  }

  @media (max-width: 768px) {
    .page-container { padding: 4rem 1.5rem; }
    .card-md { grid-column: span 12; }
    .tools-row { 
      grid-template-columns: 1fr; 
      gap: 0.75rem; 
      padding-bottom: 1rem;
    }
    .icon-grid { grid-template-columns: repeat(3, 1fr); gap: 1.25rem 0.75rem; }
    .wide-icon-grid {
      grid-template-columns: repeat(auto-fill, minmax(70px, 1fr));
      gap: 1.25rem 0.75rem;
    }
  }
</style>