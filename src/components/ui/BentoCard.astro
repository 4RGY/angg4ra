---
// Props: size = 'sm' | 'md' | 'lg' | 'xl'
// sm = 3 kolom, md = 6 kolom, lg = 9 kolom, xl = 12 kolom
const { size = 'md', class: className = '', scanline = false } = Astro.props;

const colSpan = {
  sm: 'col-span-12 md:col-span-6 lg:col-span-3',
  md: 'col-span-12 md:col-span-6',
  lg: 'col-span-12 lg:col-span-9',
  xl: 'col-span-12',
}[size];
---

<div class={`bento-card ${colSpan} ${className} ${scanline ? 'scanline' : ''}`}>
  <slot />
</div>

<style>
  .bento-card {
    background-color: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    position: relative;
    overflow: hidden;
    transition: border-color 250ms ease, box-shadow 250ms ease;
  }

  .bento-card:hover {
    border-color: var(--accent);
    box-shadow: 0 0 20px rgba(107, 45, 62, 0.15);
  }

  /* Efek scanline pada kartu tertentu */
  .scanline::after {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(255,255,255,0.01) 2px,
      rgba(255,255,255,0.01) 4px
    );
  }
</style>